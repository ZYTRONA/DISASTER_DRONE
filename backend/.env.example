# Copy to .env and fill in your values
# MongoDB Atlas configuration

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=DRONE
MONGODB_DB_NAME=drone

FLASK_PORT=5000
DEBUG=True

JWT_SECRET_KEY=change_this_to_a_long_random_string
JWT_EXPIRATION_HOURS=24

# Comma-separated allowed origins
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:19006
