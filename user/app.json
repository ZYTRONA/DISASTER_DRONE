{
  "name": "ndrf-mobile",
  "displayName": "NDRF Mobile",
  "slug": "ndrf-mobile",
  "version": "1.0.0",
  "orientation": "portrait",
  "icon": "./assets/images/icon.png",
  "userInterfaceStyle": "light",
  "splash": {
    "image": "./assets/images/splash-icon.png",
    "resizeMode": "contain",
    "backgroundColor": "#ffffff"
  },
  "assetBundlePatterns": [
    "**/*"
  ],
  "ios": {
    "requireFullScreen": true,
    "bundleIdentifier": "com.ndrf.mobile"
  },
  "android": {
    "adaptiveIcon": {
      "foregroundImage": "./assets/images/android-icon-foreground.png",
      "backgroundColor": "#ffffff"
    },
    "permissions": [
      "android.permission.ACCESS_FINE_LOCATION",
      "android.permission.ACCESS_COARSE_LOCATION",
      "android.permission.INTERNET",
      "android.permission.ACCESS_NETWORK_STATE"
    ],
    "package": "com.ndrf.mobile"
  },
  "web": {
    "favicon": "./assets/images/favicon.png"
  },
  "plugins": [
    [
      "expo-location",
      {
        "locationAlwaysAndWhenInUsePermission": "Allow NDRF to access your location for disaster relief coordination."
      }
    ]
  ],
  "scheme": "ndrfmobile",
  "description": "NDRF Mobile App for disaster management and relief coordination"
}
